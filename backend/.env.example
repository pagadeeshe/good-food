# =============================================================================
# Production stack
#   Frontend → React + Vercel
#   Backend  → Django + DRF + Railway
#   Database → Supabase PostgreSQL
#   Cache    → Upstash Redis
#   Queue    → Celery (Upstash Redis broker)
# =============================================================================

# --- Django (required) ---
DJANGO_SETTINGS_MODULE=food_ordering.settings_production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-api.up.railway.app

# --- Supabase PostgreSQL ---
# Project Settings → Database → Connection string (URI, port 5432 or pooler 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# --- Upstash Redis (cache + Celery) ---
# Upstash console → your database → REST/Redis → redis:// or rediss:// URL
REDIS_URL=rediss://default:[token]@[host].upstash.io:6379
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Vercel React frontend ---
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# --- App ---
TIME_ZONE=Asia/Kolkata
ADMIN_EMAIL=admin@foodordering.com
PORT=8000
WEB_CONCURRENCY=3
CELERY_CONCURRENCY=2
SECURE_SSL_REDIRECT=True

# --- Monitoring (optional) ---
# SENTRY_DSN=https://...
