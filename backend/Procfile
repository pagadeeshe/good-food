web: gunicorn food_ordering.wsgi:application --bind 0.0.0.0:$PORT --workers ${WEB_CONCURRENCY:-3} --timeout 120
worker: celery -A food_ordering worker --loglevel=info --concurrency=${CELERY_CONCURRENCY:-2}
beat: celery -A food_ordering beat --loglevel=info
release: python manage.py migrate --noinput && python manage.py collectstatic --noinput && python manage.py ensure_admin_user
